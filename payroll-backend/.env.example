# ====================================
# 🔒 CZKP PAYROLL BACKEND — ENVIRONMENT VARIABLES
# ====================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env TO GIT!
# Server will REFUSE TO START without required variables.

# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Authentication (REQUIRED) ───────────────
# Generate with: npm run generate:jwt-secret
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASSWORD_PEPPER=

# ── Database (PostgreSQL — REQUIRED) ────────
DATABASE_URL=postgresql://user:password@localhost:5432/czkp_payroll

# ── Encryption (REQUIRED for PII protection) ─
# Master key for AES-256-GCM encryption of rodné číslo, bank accounts, addresses
# Generate with: npm run generate:db-key
MASTER_ENCRYPTION_KEY=

# ── CORS (comma-separated origins) ─────────
ALLOWED_ORIGINS=http://localhost:8080

# ── Rate Limiting ───────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── File Upload ─────────────────────────────
MAX_FILE_SIZE_MB=5

# ── Logging ─────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ── 2FA ─────────────────────────────────────
TOTP_ISSUER=CZKP-Payroll

# ── Email (optional — for password reset) ───
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Admin Security ──────────────────────────
# Comma-separated IPs allowed to access /admin routes (empty = all)
ADMIN_IP_WHITELIST=

# ── Backup Encryption (REQUIRED for backups) ─
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=

# ── Banking / Billing ───────────────────────
BANK_NAME=
BANK_ACCOUNT=
BANK_IBAN=
USDC_ADDRESS=
SUPPORT_EMAIL=billing@your-domain.com

# ── Database SSL (production) ───────────────
DB_SSL_REJECT_UNAUTHORIZED=true
